@model List<SensorialStore.DAL.Entities.Producto>

@{
    // Definimos el título de la pestaña del navegador para la página principal
    ViewData["Title"] = "Inventario de Maquillaje";
}

<div class="container-fluid p-0">
    <h2 class="mb-4" style="color: #222222; font-weight: 600; font-size: 1.6rem;">Inventario de Maquillaje</h2>

    <div class="card border-0 shadow-sm" style="background-color: #ffffff; border-radius: 12px; border: 1px solid #efe4e2 !important;">

        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3" style="border-bottom: 1px solid #efe4e2;">
            <h5 class="m-0 text-dark" style="font-weight: 600;">Catálogo de Productos</h5>
            <button class="btn" style="background-color: #d78277; color: white; font-weight: 500;" data-bs-toggle="modal" data-bs-target="#modalCrear">
                <i class="fa-solid fa-plus me-1"></i> Agregar Nuevo Producto
            </button>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead style="background-color: #faf3f1; color: #555555;">
                    <tr>
                        <th class="ps-4" style="width: 80px;">Imagen</th>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Marca</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th class="text-center" style="width: 120px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="rounded d-flex align-items-center justify-content-center overflow-hidden" style="width: 50px; height: 50px; border: 1px solid #eaddda; background-color: #fff;">
                                    @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                    {
                                        <img src="@item.ImagenUrl" style="width: 100%; height: 100%; object-fit: cover;" alt="Producto" />
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-image text-muted" style="font-size: 0.9rem;"></i>
                                    }
                                </div>
                            </td>

                            <td>
                                <span class="fw-bold text-dark">@item.Nombre</span><br />
                                <small class="text-muted">@item.Descripcion</small>
                            </td>

                            <td><span class="badge px-2 py-1 rounded-pill" style="background-color: #f7e6e4; color: #b55d51;">@item.Categoria?.Nombre</span></td>

                            <td><span class="badge px-2 py-1 rounded-pill" style="background-color: #f2e1d8; color: #825b43;">@item.Marca?.Nombre</span></td>

                            <td class="fw-semibold text-secondary">$@item.Precio.ToString("N0")</td>

                            <td class="fw-bold text-success">@item.Stock</td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-link text-secondary p-1"
                                        onclick="abrirEditar('@item.ProductoId',
                                                '@item.Nombre',
                                                '@item.Descripcion',
                                                '@item.Precio.ToString("0")', '@item.Stock',
                                                '@item.CategoriaId',
                                                '@item.MarcaId',
                                                '@item.ImagenUrl')">
                                    <i class="fa-solid fa-pen"></i>
                                </button>

                                <form asp-action="Eliminar" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.ProductoId" />
                                    <button type="submit" class="btn btn-sm btn-link text-danger p-1" onclick="return confirm('¿Deseas quitar este producto?')">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCrear" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header text-white" style="background-color: #d78277;">
                <h5 class="modal-title fw-bold">Agregar Nuevo Producto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Crear" method="post">
                <div class="modal-body p-4">

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Enlace de la Imagen (URL de Internet)</label>
                        <input type="text" class="form-control" name="ImagenUrl" placeholder="https://ejemplo.com/foto-maquillaje.png" required style="border: 1px solid #cccccc; border-radius: 6px; padding: 8px;" />
                        <span class="form-text text-muted" style="font-size: 0.8rem;">Busca el producto en Google, haz clic derecho en la foto, selecciona 'Copiar dirección de imagen' y pégala aquí.</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Nombre del Producto</label>
                        <input name="Nombre" class="form-control" placeholder="Nombre" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Descripción</label>
                        <textarea name="Descripcion" class="form-control" placeholder="Descripción" rows="2"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary">Categoría</label>
                            <select name="CategoriaId" class="form-select">
                                @foreach (var c in ViewBag.Categorias)
                                {
                                    <option value="@c.CategoriaId">@c.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary">Marca</label>
                            <select name="MarcaId" class="form-select">
                                @foreach (var m in ViewBag.Marcas)
                                {
                                    <option value="@m.MarcaId">@m.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary">Precio</label>
                            <input name="Precio" type="number" step="any" class="form-control" placeholder="Ej: 40000" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary">Stock</label>
                            <input name="Stock" type="number" class="form-control" placeholder="Stock" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-sm px-3" style="background-color: #d78277; color: white;">Guardar Producto</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header text-white" style="background-color: #c46f64;">
                <h5 class="modal-title fw-bold">Modificar Producto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Editar" method="post">
                <input type="hidden" name="ProductoId" id="editId" />
                <div class="modal-body p-4">

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Enlace de la Imagen (URL de Internet)</label>
                        <input type="text" class="form-control" name="ImagenUrl" id="editImagenUrl" required style="border: 1px solid #cccccc; border-radius: 6px; padding: 8px;" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Nombre del Producto</label>
                        <input name="Nombre" id="editNombre" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Descripción</label>
                        <textarea name="Descripcion" id="editDescripcion" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary">Categoría</label>
                            <select name="CategoriaId" id="editCat" class="form-select">
                                @foreach (var c in ViewBag.Categorias)
                                {
                                    <option value="@c.CategoriaId">@c.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary">Marca</label>
                            <select name="MarcaId" id="editMarca" class="form-select">
                                @foreach (var m in ViewBag.Marcas)
                                {
                                    <option value="@m.MarcaId">@m.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary">Precio</label>
                            <input name="Precio" id="editPrecio" type="number" step="any" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-secondary">Stock</label>
                            <input name="Stock" id="editStock" type="number" class="form-control" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-dark btn-sm px-3">Actualizar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Esta función recibe todos los datos de la fila del producto seleccionado cuando presionamos el lápiz
    function abrirEditar(id, nombre, desc, precio, stock, catId, marcaId, imgUrl) {
        // Busca cada input del modal de edición por su ID único y le inyecta el valor actual para poder modificarlo
        document.getElementById('editId').value = id;
        document.getElementById('editNombre').value = nombre;
        document.getElementById('editDescripcion').value = desc;
        document.getElementById('editPrecio').value = precio;
        document.getElementById('editStock').value = stock;
        document.getElementById('editCat').value = catId;
        document.getElementById('editMarca').value = marcaId;
        document.getElementById('editImagenUrl').value = imgUrl; // Mantiene cargado el link actual en la edición

        // Abre de manera visual en pantalla el modal que acabamos de llenar
        new bootstrap.Modal(document.getElementById('modalEditar')).show();
    }
</script>